          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"{{checkin_date}}\",\n  \"rooms_available\": 5,\n  \"update_source\": \"owner_whatsapp\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/lodges/{{lodge_id}}/availability", "host": ["{{baseUrl}}"], "path": ["lodges", "{{lodge_id}}", "availability"] },
            "description": "Mirrors the lodge owner's daily `AVAIL 5` WhatsApp reply."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create booking",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('idempotency_key', 'idem-' + Date.now());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('booking_ref', body.booking_ref);",
                  "console.log('Saved booking_ref =', body.booking_ref);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{idempotency_key}}", "description": "Duplicate POSTs with the same key return the original booking instead of double-holding." }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"devotee_phone\": \"{{devotee_phone}}\",\n  \"devotee_name\": \"Kavitha\",\n  \"lodge_id\": \"{{lodge_id}}\",\n  \"checkin_date\": \"{{checkin_date}}\",\n  \"checkin_time\": \"early_morning\",\n  \"payment_method\": \"gpay\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] },
            "description": "`checkin_time` ∈ `night_before | early_morning | morning | afternoon_or_later`.\n\n`payment_method` ∈ `gpay | phonepe | paytm | bhim | bank_transfer | razorpay | paypal | wise`."
          },
          "response": []
        },
        {
          "name": "List bookings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/bookings?phone={{devotee_phone}}&status=pending&limit=50&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["bookings"],
              "query": [
                { "key": "phone", "value": "{{devotee_phone}}" },
                { "key": "status", "value": "pending" },
                { "key": "limit", "value": "50" },
                { "key": "offset", "value": "0" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get booking by reference",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/bookings/{{booking_ref}}", "host": ["{{baseUrl}}"], "path": ["bookings", "{{booking_ref}}"] }
          },
          "response": []
        },
        {
          "name": "Confirm payment (Rs.49)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payment_reference\": \"UPI-TXN-2026052900042\",\n  \"screenshot_url\": \"https://supabase.example/proofs/kavitha-may23.jpg\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/bookings/{{booking_ref}}/confirm-payment", "host": ["{{baseUrl}}"], "path": ["bookings", "{{booking_ref}}", "confirm-payment"] }
          },
          "response": []
        },
        {
          "name": "Cancel booking (devotee)",
          "request": {
            "method": "POST",
            "header": [],
            "body": { "mode": "raw", "raw": "" },
            "url": {
              "raw": "{{baseUrl}}/bookings/{{booking_ref}}/cancel?cancelled_by_lodge=false",
              "host": ["{{baseUrl}}"],
              "path": ["bookings", "{{booking_ref}}", "cancel"],
              "query": [{ "key": "cancelled_by_lodge", "value": "false" }]
            },
            "description": "24-hour refund rule (IST): full refund if 24h+ away, none if under 24h, `cancelled_by_lodge=true` always full refund."
          },
          "response": []
        },
        {
          "name": "Cancel booking (lodge-initiated)",
          "request": {
            "method": "POST",
            "header": [],
            "body": { "mode": "raw", "raw": "" },
            "url": {
              "raw": "{{baseUrl}}/bookings/{{booking_ref}}/cancel?cancelled_by_lodge=true",
              "host": ["{{baseUrl}}"],
              "path": ["bookings", "{{booking_ref}}", "cancel"],
              "query": [{ "key": "cancelled_by_lodge", "value": "true" }]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string", "description": "Service root URL." },
    { "key": "devotee_phone", "value": "9876543210", "type": "string", "description": "WhatsApp number used across devotee + webhook + booking flows." },
    { "key": "visit_date", "value": "2026-06-15", "type": "string", "description": "Planned visit date for Feature 1 flows." },
    { "key": "checkin_date", "value": "2026-06-15", "type": "string", "description": "Lodge check-in date for Feature 6 flows." },
    { "key": "lodge_id", "value": "", "type": "string", "description": "Auto-set by 'Lodges / Create lodge' test script." },
    { "key": "booking_ref", "value": "", "type": "string", "description": "Auto-set by 'Bookings / Create booking' test script." },
    { "key": "idempotency_key", "value": "", "type": "string", "description": "Refreshed per click by the booking pre-request script." }
  ]
}
