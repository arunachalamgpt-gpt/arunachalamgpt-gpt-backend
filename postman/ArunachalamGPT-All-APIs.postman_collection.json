            "url": { "raw": "{{baseUrl}}/webhook/whatsapp", "host": ["{{baseUrl}}"], "path": ["webhook", "whatsapp"] },
            "description": "Free-form English that the keyword path catches via 'how long' → none. LLM should classify as `ask_crowd` or `ask_plan`."
          },
          "response": []
