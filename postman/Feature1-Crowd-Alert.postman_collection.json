        {
          "name": "LLM — romanized Tamil crowd query",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"{{devotee_phone}}\",\n  \"text\": \"crowd enna ippo?\"\n}" },
            "url": { "raw": "{{baseUrl}}/webhook/whatsapp", "host": ["{{baseUrl}}"], "path": ["webhook", "whatsapp"] },
            "description": "Requires OPENAI_ENABLED=true. With LLM off this still works via the keyword path (matches `crowd`)."
          },
          "response": []
        },
        {
          "name": "LLM — romanized Tamil planning query",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"{{devotee_phone}}\",\n  \"text\": \"epdi varuvadhu best time?\"\n}" },
            "url": { "raw": "{{baseUrl}}/webhook/whatsapp", "host": ["{{baseUrl}}"], "path": ["webhook", "whatsapp"] }
          },
          "response": []
        },
        {
          "name": "LLM — romanized Hindi language switch",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"{{devotee_phone}}\",\n  \"text\": \"hindi me bolo\"\n}" },
            "url": { "raw": "{{baseUrl}}/webhook/whatsapp", "host": ["{{baseUrl}}"], "path": ["webhook", "whatsapp"] },
            "description": "Keyword path can't handle this — LLM picks `change_language` with target=hindi."
          },
          "response": []
        },
        {
          "name": "LLM — code-mix visit registration",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"{{devotee_phone}}\",\n  \"text\": \"amma ku visit on 15/06/2026\"\n}" },
            "url": { "raw": "{{baseUrl}}/webhook/whatsapp", "host": ["{{baseUrl}}"], "path": ["webhook", "whatsapp"] },
            "description": "LLM extracts visit_date + has_elderly from 'amma'."
          },
          "response": []
        },
        {
          "name": "LLM — free-form crowd question",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"{{devotee_phone}}\",\n  \"text\": \"how long will I have to stand if I come tomorrow at 8 am\"\n}" },
            "url": { "raw": "{{baseUrl}}/webhook/whatsapp", "host": ["{{baseUrl}}"], "path": ["webhook", "whatsapp"] }
          },
          "response": []
        },
        {
          "name": "Twilio inbound (form-encoded)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" },
              { "key": "X-Twilio-Signature", "value": "<computed-by-twilio>" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "From", "value": "whatsapp:+919876543210" },
                { "key": "Body", "value": "Hi" },
                { "key": "MessageSid", "value": "SMtest123" },
                { "key": "AccountSid", "value": "ACtest" },
                { "key": "To", "value": "whatsapp:+14155238886" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/webhook/whatsapp/twilio", "host": ["{{baseUrl}}"], "path": ["webhook", "whatsapp", "twilio"] },
            "description": "Twilio's WhatsApp webhook target. Returns 503 if disabled, 403 on signature mismatch, 200 on success with `{accepted, to, reply_state, send}`."
          },
          "response": []
        }
      ]
    },
    {
