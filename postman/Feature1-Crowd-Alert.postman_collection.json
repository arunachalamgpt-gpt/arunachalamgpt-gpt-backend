          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{devotee_phone}}\",\n  \"text\": \"change to english\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/webhook/whatsapp",
              "host": ["{{baseUrl}}"],
              "path": ["webhook", "whatsapp"]
            }
          },
          "response": []
